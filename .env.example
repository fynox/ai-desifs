# Copier ce fichier en .env et remplir les valeurs

# Serveur
PORT=3000
NODE_ENV=development

# JWT - générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=votre_secret_jwt_tres_long_ici

# Base de données SQLite (chemin local ou volume Railway)
DB_PATH=./data/aidesifs.db

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_INBOUND_DOMAIN=ai-dhesif.fr

# URL du site (pour les emails)
APP_URL=https://ai-dhesif.fr
